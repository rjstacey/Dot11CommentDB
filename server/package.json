		"dotenv": "^17.4.2",
		"exceljs": "^4.4.0",
		"express": "^5.2.1",
		"googleapis": "^173.0.0",
		"http-cookie-agent": "^8.0.0",
		"jsonwebtoken": "^9.0.3",
		"lodash.isempty": "^4.4.0",
		"lodash.uniq": "^4.5.0",
