{
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"noFallthroughCasesInSwitch": true,
		"noEmit": true,
		"jsx": "react-jsx",

		"paths": {
			"@schemas/*": ["./schemas/*"],
			"@common": ["./common/src"]
		}
	},
	"include": ["./schemas", "./common/src"],
	"exclude": ["./common/src/stories", "./common/**/*.test.*"]
}
